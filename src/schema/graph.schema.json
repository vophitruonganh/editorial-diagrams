{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Editorial graph diagram spec",
  "type": "object",
  "required": ["type", "title", "nodes"],
  "properties": {
    "type": { "enum": ["flowchart", "activity", "state", "erd", "class", "dependency", "call-graph", "network", "mindmap", "org-chart", "decision-tree", "knowledge-graph", "data-lineage"] },
    "id": { "type": "string" },
    "eyebrow": { "type": "string" },
    "title": { "type": "string" },
    "subtitle": { "type": "string" },
    "caption": { "type": "string" },
    "direction": { "enum": ["TB", "LR", "BT", "RL"], "default": "TB" },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" },
          "kind": { "type": "string", "description": "node renderer (default: card)" },
          "card": { "type": "string", "description": "card DSL: \"[kind:][+]Name | [tech] | detail\"" },
          "w": { "type": "number" },
          "h": { "type": "number" }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "label": { "type": "string" },
          "style": { "enum": ["orthogonal", "rounded", "straight"], "default": "orthogonal" },
          "arrow": { "type": "boolean", "default": true }
        }
      }
    }
  }
}
